{
  "name": "ready-ssr-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch ./src/server",
    "build": "rm -rf !.gitkeep ./dist/* && npm run build:client && npm run build:server && npm run build:express",
    "build:client": "vite --config vite.config.client.ts build --ssrManifest --outDir dist/client",
    "build:server": "vite --config vite.config.client.ts build --ssr src/client/entry-server.ts --outDir dist/server --emptyOutDir false",
    "build:express": "vite --config vite.config.server.ts build --outDir dist --emptyOutDir false",
    "preview": "NODE_ENV=production node dist/index.js",
    "lint": "npm run lint:eslint && npm run lint:stylelint",
    "lint:fix": "npm run lint:eslint:fix && npm run lint:stylelint:fix",
    "lint:eslint": "eslint ./src",
    "lint:eslint:fix": "eslint ./src --fix",
    "lint:stylelint": "stylelint './src/client/**/*.{css,scss,vue}'",
    "lint:stylelint:fix": "stylelint './src/client/**/*.{css,scss,vue}' --fix"
  },
  "dependencies": {
    "@pinia/colada": "^1.3.0",
    "@types/compression": "^1.8.1",
    "@unhead/vue": "^3.1.0",
    "class-transformer": "^0.5.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "devalue": "^5.8.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "http-status": "^2.1.0",
    "pinia": "^3.0.4",
    "reflect-metadata": "^0.2.2",
    "serialize-javascript": "^7.0.5",
    "universal-cookie": "^8.1.2",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2",
    "vue-router": "5.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify/json": "^2.2.473",
    "@intlify/eslint-plugin-vue-i18n": "^4.4.0",
    "@intlify/unplugin-vue-i18n": "^11.2.0",
    "@pinia/colada-devtools": "^1.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@stylistic/stylelint-plugin": "^5.1.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "@types/serialize-javascript": "^5.0.4",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-vue": "^10.9.1",
    "postcss-scss": "^4.0.9",
    "sass": "^1.99.0",
    "stylelint": "^17.11.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-high-performance-animation": "^2.0.0",
    "stylelint-order": "^8.1.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.12",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-webfont-dl": "^3.12.0"
  },
  "engines": {
    "node": ">=22.14.0"
  }
}
