{
  "prettier.enable": false,
  "editor.formatOnSave": false,
  "editor.defaultFormatter": "dbaeumer.vscode-eslint",
  "editor.codeActionsOnSave": {
    "source.fixAll.stylelint": "explicit",
    "source.fixAll.eslint": "explicit"
  },
  "[css]": {
    "editor.defaultFormatter": "stylelint.vscode-stylelint"
  },
  "[scss]": {
    "editor.defaultFormatter": "stylelint.vscode-stylelint"
  },
  "[vue]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[javascript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "eslint.format.enable": true,
  "eslint.useFlatConfig": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "html",
    "vue",
    "stylus",
    "styl",
    "json",
    "jsonc"
  ],
  "eslint.probe": [
    "astro",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "mdx",
    "vue",
    "markdown",
    "json",
    "jsonc",
    "stylus"
  ],
  "css.validate": false,
  "less.validate": false,
  "scss.validate": false,
  "notebook.defaultFormatter": "dbaeumer.vscode-eslint",
  "languageStylus.useSeparator": true,
  "makefile.configureOnOpen": true,
  "i18n-ally.localesPaths": [
    "src/client/locales/**",
  ],
  "i18n-ally.enabledFrameworks": [
    "vue"
  ],
  "i18n-ally.enabledParsers": [
    "json"
  ],
  "i18n-ally.dirStructure": "auto",
  "i18n-ally.keystyle": "nested",
  "i18n-ally.extract.autoDetect": true,
  "i18n-ally.extract.parsers.html": {
    "ignoredTags": [
      "script",
      "style",
      "template"
    ],
  },
  "i18n-ally.sourceLanguage": "ru",
  "i18n-ally.displayLanguage": "ru",
  "stylelint.run": "onSave",
  "stylelint.snippet": [
    "css",
    "postcss",
    "scss"
  ],
  "stylelint.validate": [
    "css",
    "postcss",
    "scss",
    "vue"
  ],
  "scss.showErrors": true,
  "scss.suggestVariables": true,
  "cssVariables.blacklistFolders": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/node_modules",
    "**/bower_components",
    "**/tmp",
    "**/dist",
    "dist",
    "**/tests"
  ],
  "workbench.browser.dataStorage": "workspace",
  "simpleBrowser.focusLockIndicator.enabled": true,
}
